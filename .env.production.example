# ─────────────────────────────────────────────────────────────────────────
# ECHAMELO — runtime environment variables
#
# In cPanel these go in the "Setup Node.js App" screen under "Environment
# variables", NOT in a file inside the upload. Fill in the real values.
#
# IMPORTANT: the NEXT_PUBLIC_* values are baked into the app when it is BUILT,
# not read at runtime. The zip you upload already has the values that were in
# .env.local at build time. To change a NEXT_PUBLIC_* value (e.g. swap test
# Stripe keys for live keys) you must rebuild and re-upload — setting it in
# cPanel alone will NOT change it. The secret (non-public) values below ARE
# read at runtime, so those you set in cPanel.
# ─────────────────────────────────────────────────────────────────────────

# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key        # SECRET — runtime

# --- LiveKit ---
NEXT_PUBLIC_LIVEKIT_URL=wss://YOUR-PROJECT.livekit.cloud
LIVEKIT_API_KEY=your-livekit-key                       # SECRET — runtime
LIVEKIT_API_SECRET=your-livekit-secret                 # SECRET — runtime

# --- Stripe ---
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_or_test_...
STRIPE_SECRET_KEY=sk_live_or_test_...                  # SECRET — runtime
STRIPE_WEBHOOK_SECRET=whsec_...                        # SECRET — runtime

# --- Resend (transactional email) ---
RESEND_API_KEY=re_...                                  # SECRET — runtime

# --- Cron jobs ---
CRON_SECRET=your-secret-key-for-verifying-cron-calls  # SECRET — runtime

# --- Runtime ---
NODE_ENV=production
